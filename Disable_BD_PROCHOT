#!/bin/bash
set -u

printf "Disabling BD PROCHOT on Linux\n\n"
printf "This installer sets up BD PROCHOT disabling at boot and after every resume\n"
printf "from suspend, hibernate, hybrid-sleep and suspend-then-hibernate.\n\n"
printf "Works on standard and immutable distributions (e.g. Bazzite, Silverblue, Kinoite)\n"
printf "by placing all units under /etc/systemd/system/.\n\n"

while true; do
    read -rp "Do you want to continue? [y/N]: " yn
    case $yn in
        [Yy]* ) break;;
        [Nn]* ) exit;;
        * ) printf "Error: please answer 'y' or 'n'\n";;
    esac
done

if [ "$(id -u)" != 0 ]; then
    printf "This script requires administrator privileges\n"
    exec sudo "$0" "$@"
fi

# --- Kernel lockdown pre-check ---
# When Secure Boot is enabled on Ubuntu / Mint / Debian / Fedora distro kernels,
# the kernel lockdown LSM auto-engages in 'integrity' mode and blocks wrmsr writes
# to /dev/cpu/*/msr with EPERM. Detect this before installing so the user knows
# the services will fail until lockdown is lifted.
LOCKDOWN_MODE="none"
if [ -r /sys/kernel/security/lockdown ]; then
    LOCKDOWN_MODE="$(awk -F'[][]' '/\[/ {print $2}' /sys/kernel/security/lockdown 2>/dev/null || true)"
    [ -z "$LOCKDOWN_MODE" ] && LOCKDOWN_MODE="none"
fi

if [ "$LOCKDOWN_MODE" != "none" ]; then
    printf "\n⚠ Kernel lockdown is active (mode: %s).\n" "$LOCKDOWN_MODE"
    printf "  This will block MSR writes; the worker will fail with:\n"
    printf "    wrmsr: pwrite: Operation not permitted\n\n"
    printf "  Typical cause: Secure Boot enabled on a distro kernel that auto-locks\n"
    printf "  (Ubuntu, Linux Mint, Debian, Fedora).\n\n"
    printf "Choose how to proceed:\n"
    printf "  1) Abort. Reboot into UEFI firmware, disable Secure Boot, then re-run\n"
    printf "     this installer. Cleanest fix, no further steps required. (recommended)\n"
    printf "  2) Run 'mokutil --disable-validation' now. Sets a one-time password;\n"
    printf "     at the next reboot the MOK Manager menu asks you to confirm with\n"
    printf "     that password. After confirmation, shim boots in insecure mode and\n"
    printf "     kernel lockdown no longer engages. Reversible with\n"
    printf "     'sudo mokutil --enable-validation'. Security impact is equivalent\n"
    printf "     to disabling Secure Boot.\n"
    printf "  3) Install anyway. Services will be created but the worker will fail\n"
    printf "     on every run until you lift lockdown manually (see README\n"
    printf "     Troubleshooting for the 'lsm=' GRUB cmdline workaround).\n"
    printf "  4) Abort without doing anything.\n\n"
    while true; do
        read -rp "Choice [1/2/3/4]: " lkopt
        case $lkopt in
            1 ) printf "\nReboot → UEFI firmware → disable Secure Boot → re-run this installer.\n"; exit 0;;
            2 )
                if ! command -v mokutil >/dev/null 2>&1; then
                    printf "Error: mokutil is not installed.\n"
                    printf "  Debian/Ubuntu/Mint: sudo apt install mokutil\n"
                    printf "  Fedora:             sudo dnf install mokutil\n"
                    printf "  Arch:               sudo pacman -S mokutil (AUR)\n"
                    printf "Install it, then re-run this script.\n"
                    exit 1
                fi
                printf "\nRunning 'mokutil --disable-validation'.\n"
                printf "Pick a one-time password (8-16 chars). You will type it again at the\n"
                printf "MOK Management screen on next reboot to confirm.\n\n"
                if mokutil --disable-validation; then
                    printf "\n✓ Secure Boot validation queued for disable on next reboot.\n"
                    printf "  Re-enable later with: sudo mokutil --enable-validation\n\n"
                    break
                else
                    printf "\n✗ mokutil failed. Pick another option.\n\n"
                fi
                ;;
            3 ) printf "\nProceeding. After install + reboot, verify with:\n"
                printf "  sudo rdmsr -a 0x1FC    # if it errors with 'Operation not permitted', see README\n\n"
                break;;
            4 ) exit 0;;
            * ) printf "Error: enter 1, 2, 3 or 4\n";;
        esac
    done
fi

printf "\nInstalling msr-tools...\n\n"
printf "Which package manager do you want to use?\n\n"
printf "1. Arch Linux (pacman)\n"
printf "2. Ubuntu / Debian and derivatives (apt)\n"
printf "3. Fedora / Bazzite / Silverblue / Kinoite (rpm-ostree)\n"
printf "4. Fedora / CentOS / RHEL (dnf)\n"
printf "5. Skip (already installed)\n\n"

NEEDS_REBOOT_FOR_PKG=0
while true; do
    read -rp "Choose an option [1/2/3/4/5]: " option
    case $option in
        1 ) pacman -S --needed msr-tools; break;;
        2 ) apt-get update && apt-get install -y msr-tools; break;;
        3 ) rpm-ostree install --idempotent --allow-inactive msr-tools; NEEDS_REBOOT_FOR_PKG=1; break;;
        4 ) dnf install -y msr-tools; break;;
        5 ) break;;
        * ) printf "Error: please enter a number between 1 and 5\n";;
    esac
done

# --- Persist msr kernel module across reboots ---
printf "\nPersisting msr kernel module...\n"
echo msr > /etc/modules-load.d/msr.conf
modprobe msr 2>/dev/null || true
printf "✓ /etc/modules-load.d/msr.conf written\n"

# --- Main worker script ---
printf "\nCreating main worker script at /usr/local/bin/disable_bd_prochot.sh...\n"
cat > /usr/local/bin/disable_bd_prochot.sh << 'EOL'
#!/bin/bash
# Disable BD PROCHOT by clearing bit 0 of MSR 0x1FC (MSR_POWER_CTL).
# Uses dynamic bit masking so it stays correct across CPU models.
# Logs failures to the journal (tag: disable_bd_prochot) so kernel lockdown
# or a missing msr module is visible in journalctl instead of silent exit.

modprobe msr 2>/dev/null || true

shopt -s nullglob
cpus=(/dev/cpu/[0-9]*)
if [ ${#cpus[@]} -eq 0 ]; then
    logger -t disable_bd_prochot "no /dev/cpu/*/msr devices — msr module unavailable"
    exit 1
fi

if [ -r /sys/kernel/security/lockdown ]; then
    mode="$(awk -F'[][]' '/\[/ {print $2}' /sys/kernel/security/lockdown 2>/dev/null || true)"
    if [ -n "$mode" ] && [ "$mode" != "none" ]; then
        logger -t disable_bd_prochot "kernel lockdown active (mode: $mode) — wrmsr will likely fail; see README"
    fi
fi

fail=0
for cpu in "${cpus[@]}"; do
    cpu_id="${cpu##*/cpu/}"
    cpu_id="${cpu_id%%/*}"
    if ! current_hex="$(rdmsr -p "$cpu_id" 0x1FC 2>/dev/null)"; then
        logger -t disable_bd_prochot "rdmsr failed on cpu $cpu_id"
        fail=1
        continue
    fi
    current_dec=$((16#${current_hex}))
    new_dec=$(( current_dec & ~1 ))
    new_hex=$(printf '%x' "$new_dec")
    if ! wrmsr -p "$cpu_id" 0x1FC "0x${new_hex}" 2>/dev/null; then
        logger -t disable_bd_prochot "wrmsr failed on cpu $cpu_id (Operation not permitted? kernel lockdown — see README)"
        fail=1
    fi
done

exit $fail
EOL
chmod 0755 /usr/local/bin/disable_bd_prochot.sh
printf "✓ Worker script installed\n"

# --- Boot service (runs once at boot) ---
printf "\nCreating boot service at /etc/systemd/system/disable_bd_prochot.service...\n"
cat > /etc/systemd/system/disable_bd_prochot.service << 'EOF'
[Unit]
Description=Disable BD PROCHOT at boot
After=multi-user.target
ConditionPathExists=/usr/local/bin/disable_bd_prochot.sh

[Service]
Type=oneshot
ExecStart=/usr/local/bin/disable_bd_prochot.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
EOF
printf "✓ Boot service written\n"

# --- Resume service (runs after every sleep state) ---
printf "\nCreating resume service at /etc/systemd/system/disable_bd_prochot-resume.service...\n"
cat > /etc/systemd/system/disable_bd_prochot-resume.service << 'EOF'
[Unit]
Description=Disable BD PROCHOT on resume from suspend/hibernate
After=suspend.target hibernate.target hybrid-sleep.target suspend-then-hibernate.target
ConditionPathExists=/usr/local/bin/disable_bd_prochot.sh

[Service]
Type=oneshot
ExecStart=/usr/local/bin/disable_bd_prochot.sh

[Install]
WantedBy=suspend.target hibernate.target hybrid-sleep.target suspend-then-hibernate.target
EOF
printf "✓ Resume service written\n"

# --- Clean up any leftover legacy sleep hook from previous installations ---
for legacy in /usr/lib/systemd/system-sleep/disable_bd_prochot /lib/systemd/system-sleep/disable_bd_prochot; do
    if [ -e "$legacy" ]; then
        rm -f "$legacy" 2>/dev/null && printf "✓ Removed legacy hook %s\n" "$legacy" \
            || printf "⚠ Could not remove legacy hook %s (read-only filesystem?)\n" "$legacy"
    fi
done

# --- Enable and start ---
printf "\nEnabling services...\n"
systemctl daemon-reload
systemctl enable --now disable_bd_prochot.service
systemctl enable disable_bd_prochot-resume.service
printf "✓ Services enabled\n"

printf "\nDone. Quick verification:\n"
printf "  rdmsr -a 0x1FC   # last hex digit should be even (bit 0 = 0)\n\n"

if [ "$NEEDS_REBOOT_FOR_PKG" -eq 1 ]; then
    printf "⚠ rpm-ostree staged msr-tools in the next deployment. You MUST reboot\n"
    printf "  for the package to become available; the services will work after that.\n\n"
fi

while true; do
    read -rp "Reboot now? [y/N]: " yn
    case $yn in
        [Yy]* ) reboot; break;;
        [Nn]* ) printf "\nInstallation complete. Reboot when convenient for full effect.\n"; exit;;
        * ) printf "Error: please answer 'y' or 'n'\n";;
    esac
done
