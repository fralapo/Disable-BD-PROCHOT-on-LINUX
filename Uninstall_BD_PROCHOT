#!/bin/bash
set -u

printf "Uninstalling BD PROCHOT Disabler\n\n"
printf "This will remove every file and unit created by the installer, including\n"
printf "the resume service used on both standard and immutable distributions.\n\n"

while true; do
    read -rp "Continue with uninstallation? [y/N]: " yn
    case $yn in
        [Yy]* ) break;;
        [Nn]* ) exit;;
        * ) printf "Error: please answer 'y' or 'n'\n";;
    esac
done

if [ "$(id -u)" != 0 ]; then
    printf "This script requires administrator privileges\n"
    exec sudo "$0" "$@"
fi

printf "\nStopping and disabling services...\n"
for unit in disable_bd_prochot.service disable_bd_prochot-resume.service; do
    systemctl stop "$unit" 2>/dev/null && printf "✓ Stopped %s\n" "$unit" || printf "⚠ %s was not running\n" "$unit"
    systemctl disable "$unit" 2>/dev/null && printf "✓ Disabled %s\n" "$unit" || printf "⚠ %s was not enabled\n" "$unit"
done

printf "\nRemoving unit files...\n"
for unit_path in \
    /etc/systemd/system/disable_bd_prochot.service \
    /etc/systemd/system/disable_bd_prochot-resume.service; do
    if [ -f "$unit_path" ]; then
        rm -f "$unit_path" && printf "✓ Removed %s\n" "$unit_path"
    fi
done

printf "\nRemoving legacy sleep hooks (if any)...\n"
for legacy in /usr/lib/systemd/system-sleep/disable_bd_prochot /lib/systemd/system-sleep/disable_bd_prochot; do
    if [ -e "$legacy" ]; then
        rm -f "$legacy" 2>/dev/null && printf "✓ Removed %s\n" "$legacy" \
            || printf "⚠ Could not remove %s (read-only filesystem — safe to ignore)\n" "$legacy"
    fi
done

printf "\nRemoving worker script...\n"
if [ -f /usr/local/bin/disable_bd_prochot.sh ]; then
    rm -f /usr/local/bin/disable_bd_prochot.sh && printf "✓ Worker script removed\n"
fi

printf "\nRemoving msr module persistence...\n"
if [ -f /etc/modules-load.d/msr.conf ]; then
    rm -f /etc/modules-load.d/msr.conf && printf "✓ /etc/modules-load.d/msr.conf removed\n"
fi

printf "\nReloading systemd...\n"
systemctl daemon-reload
systemctl reset-failed 2>/dev/null || true
printf "✓ Systemd reloaded\n"

printf "\n✓ Uninstallation complete.\n"
printf "BD PROCHOT will be re-enabled by the CPU on the next reboot and will resume\n"
printf "normal thermal throttling behavior.\n\n"

while true; do
    read -rp "Reboot now? [y/N]: " yn
    case $yn in
        [Yy]* ) reboot; break;;
        [Nn]* ) printf "\nPlease reboot when convenient for changes to take full effect.\n"; exit;;
        * ) printf "Error: please answer 'y' or 'n'\n";;
    esac
done
